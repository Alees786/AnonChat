// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is user blocked?
    function isBlocked() {
      return exists(/databases/$(database)/documents/blocked/$(request.auth.uid));
    }

    // Settings — read by all auth users, write only from admin SDK (server)
    match /settings/{doc} {
      allow read: if request.auth != null;
      allow write: if false; // only admin SDK writes this
    }

    // Users — auth users read/write own doc
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // Blocked list — readable by auth users (to self-check), written by admin SDK
    match /blocked/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Rooms & messages
    match /rooms/{roomId}/messages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isBlocked();
      allow delete: if false; // admin SDK only
    }

    // DMs
    match /dms/{dmId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create, update: if request.auth != null && request.auth.uid in request.resource.data.members;
    }

    match /dms/{dmId}/messages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isBlocked();
      allow delete: if false; // admin SDK only
    }
  }
}
